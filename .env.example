# Environment Variables for Atlas Creative Studio
# Copy this file to .env and add your actual values.

# Placeholder values - replace these with your real keys

# (Optional) Google Analytics ID
# NEXT_PUBLIC_GA_ID=UA-XXXXXXXXX-X

# (Optional) Contact Form API Key (e.g., Resend)
# RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# (Optional) If you want to change the base URL later
# NEXT_PUBLIC_BASE_URL=https://www.atlascreativestudio.com

# (Unused for Static Export, kept for reference)
# DATABASE_URL=
# NEXTAUTH_SECRET=